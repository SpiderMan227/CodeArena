PORT=5000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codearena?schema=public"
JWT_ACCESS_SECRET="your-jwt-access-secret"
JWT_REFRESH_SECRET="your-jwt-refresh-secret"
